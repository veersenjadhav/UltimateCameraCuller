<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Title>UltimateCameraCuller</Title>
    <Description>Fastest GPU Frustum Culling using Clip Space math and Smart Precision.</Description>
    <Version>1.0.0</Version>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="FastMatrixEngine" Version="1.0.1" />
    <PackageReference Include="ILGPU" Version="1.5.3" />
  </ItemGroup>

</Project>
